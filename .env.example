# Ifex chat — required for /api/ifex/* endpoints

# Reuse the key from sprks. Set in Vercel project env vars for prod.
ANTHROPIC_API_KEY=

# Neon Postgres connection string. Get from Neon console.
# Example: postgres://user:pass@ep-xyz.neon.tech/neondb?sslmode=require
DATABASE_URL=

# GitHub PAT for the build-time stats fetch. Zero scopes needed for public data.
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=
